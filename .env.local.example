# ------------------------------------------------------------
# Core app keys
# ------------------------------------------------------------

# Runtime model provider for text chat + voice
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_SCORING_MODEL=gpt-4.1-mini

# Optional legacy Anthropic usage for evals / scripts
ANTHROPIC_API_KEY=

# ------------------------------------------------------------
# Supabase
# ------------------------------------------------------------

# Required for voice rate limiting and optional vector/RAG tables
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ------------------------------------------------------------
# Optional observability
# ------------------------------------------------------------

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ------------------------------------------------------------
# Optional alerts / email
# ------------------------------------------------------------

RESEND_API_KEY=
ALERT_EMAIL=

# ------------------------------------------------------------
# Optional ops / testing
# ------------------------------------------------------------

OPS_DASHBOARD_SECRET=
PROMPT_REGRESSION_SECRET=
CRON_SECRET=
ENABLE_ONLINE_SCORING=false

# ------------------------------------------------------------
# Optional local scripts / CI helpers
# ------------------------------------------------------------

CHAT_API_URL=http://localhost:5173
OPS_TEST_BASE_URL=http://localhost:5173
GITHUB_TOKEN=
INDEXNOW_ENABLED=false
