{
  "name": "multi_turn",
  "description": "Multi-turn memory checks.",
  "tests": [
    {
      "id": "multi-turn-project-followup",
      "description": "Should answer a follow-up about the previously mentioned project.",
      "input": "What stack did it use?",
      "lang": "en",
      "conversation": [
        {
          "role": "user",
          "content": "Tell me about ATS Resume Checker."
        },
        {
          "role": "assistant",
          "content": "ATS Resume Checker is an AI resume analyzer Ankit built with Next.js 15, TypeScript, and Gemini 3 Pro."
        },
        {
          "role": "user",
          "content": "What stack did it use?"
        }
      ],
      "assertions": [
        {
          "type": "contains_any",
          "values": [
            "Next.js",
            "TypeScript",
            "Gemini"
          ]
        }
      ]
    }
  ]
}
