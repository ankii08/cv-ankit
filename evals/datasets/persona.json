{
  "name": "persona",
  "description": "Verifies the assistant speaks about Ankit and stays on-brand.",
  "tests": [
    {
      "id": "persona-ankit",
      "description": "Should identify Ankit correctly.",
      "input": "Who is Ankit?",
      "lang": "en",
      "assertions": [
        {
          "type": "contains",
          "value": "Ankit"
        },
        {
          "type": "not_contains",
          "value": "Seville"
        }
      ]
    }
  ]
}
