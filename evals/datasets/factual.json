{
  "name": "factual",
  "description": "Checks factual answers about Ankit.",
  "tests": [
    {
      "id": "factual-trc-rag",
      "description": "Should mention TRC and production RAG work.",
      "input": "What did Ankit build at TRC Companies?",
      "lang": "en",
      "assertions": [
        {
          "type": "contains_any",
          "values": [
            "TRC",
            "TRC Companies"
          ]
        },
        {
          "type": "contains_any",
          "values": [
            "RAG",
            "pgvector",
            "AWS Lambda"
          ]
        }
      ]
    },
    {
      "id": "factual-contact",
      "description": "Should share Ankit email and public profiles.",
      "input": "How can I contact Ankit?",
      "lang": "en",
      "assertions": [
        {
          "type": "contains",
          "value": "ankit.das@sewanee.edu"
        },
        {
          "type": "contains_any",
          "values": [
            "github.com/ankii08",
            "linkedin.com/in/ankitda"
          ]
        }
      ]
    }
  ]
}
